[resource]
script = ExtResource("1_x6wsy")
text = "Notice how the hamsters stamina slowly drains!\\nIf you let it drain too much its health will deplete and it will die... We need the work force healthy...\\nNotice how the current power being created is increased while your hamster is running.\\nIf there is more power being generated than consumed it will be stored in the batter.\\nOn the other hand if you don't generate enough power your battery will slowly drain.\\nIf your battery reaches 0 then you lose the game and the invention is DESTROYED!\\n"
step_number = 3
next_step = ExtResource("1_vmrui")
metadata/_custom_type_script = "uid://cwb3vuo1m787c"
